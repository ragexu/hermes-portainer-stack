FROM nikolaik/python-nodejs:python3.11-nodejs22

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential curl git ripgrep ffmpeg \
    php php-cli php-curl php-mbstring php-xml php-zip unzip \
    && rm -rf /var/lib/apt/lists/*

# Composer
RUN curl -sS https://getcomposer.org/installer | php -- \
    --install-dir=/usr/local/bin --filename=composer

# Angular CLI
RUN npm install -g @angular/cli

# Rust
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs -o /tmp/rustup-init.sh \
    && chmod +x /tmp/rustup-init.sh \
    && /tmp/rustup-init.sh -y --no-modify-path \
    && rm -f /tmp/rustup-init.sh

# Set Rust PATH on its own line — no inline comments on ENV
ENV PATH="/root/.cargo/bin:${PATH}"

# Verify all tools
RUN ng version && php --version && composer --version && rustc --version && cargo --version

WORKDIR /workspace
